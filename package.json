{
  "name": "fcg-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env __NEXT_DEVTOOL_SEGMENT_EXPLORER=0 next dev",
    "dev:clean": "powershell -NoProfile -Command \"Get-NetTCPConnection -State Listen -LocalPort 3000,3001 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force }; $env:__NEXT_DEVTOOL_SEGMENT_EXPLORER='0'; next dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.19",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
